{
  "manifest_version": 3,
  "name": "Code Stego",
  "version": "3.0.0",
  "description": "Encrypt and share secret messages via Base62 encoded codes",
  "permissions": ["clipboardWrite", "clipboardRead"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
